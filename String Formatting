def print_formatted(number):
    # Calculate the width of the binary representation of 'number'
    width = len(bin(number)[2:])
    
    for i in range(1, number + 1):
        # Generate strings for each base
        # [2:] slices off the prefix (0o, 0x, 0b)
        dec = str(i)
        octal = oct(i)[2:]
        hexa = hex(i)[2:].upper()
        binary = bin(i)[2:]
        
        # Print each formatted to the calculated width
        print(f"{dec.rjust(width)} {octal.rjust(width)} {hexa.rjust(width)} {binary.rjust(width)}")


