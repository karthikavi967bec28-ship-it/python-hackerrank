import os
from datetime import datetime

# Complete the time_delta function below.
def time_delta(t1, t2):
    # The format matches: Day dd Mon yyyy hh:mm:ss +xxxx
    fmt = '%a %d %b %Y %H:%M:%S %z'
    
    # Parse the strings into aware datetime objects
    time1 = datetime.strptime(t1, fmt)
    time2 = datetime.strptime(t2, fmt)
    
    # Calculate the difference, convert to total seconds, and return as absolute string
    diff = int(abs((time1 - time2).total_seconds()))
    return str(diff)

if __name__ == '__main__':
    # Reading number of test cases
    t = int(input())

    for t_itr in range(t):
        t1 = input()
        t2 = input()

        result = time_delta(t1, t2)
